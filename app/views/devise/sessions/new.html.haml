/ Title
%span.mb-0.fs-1 👋
%h1.fs-2 Inicio de Sesión
/ Form START
= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: :false }) do |f|
  - if false
    / Email
    .mb-4
      %label.form-label{:for => "InputEmail"} Correo electrónico *
      .input-group.input-group-lg
        %span.input-group-text.bg-light.rounded-start.border-0.text-secondary.px-3
          %i.fas.fa-envelope
        %input#InputEmail.form-control.border-0.bg-light.rounded-end.ps-1{placeholder: "mail@example.com", type: :email, name: "user[email]", required: true, autofocus: true}

  / CI
  .mb-4
    %label.form-label{:for => "inputCi"} Cédula de Identidad *
    .input-group.input-group-lg{required: true}
      %span.input-group-text.bg-light.rounded-start.border-0.text-secondary.px-3
        %i.fas.fa-id-card
      %input#inputCi.form-control.border-0.bg-light.rounded-end.ps-1{type: :text, name: "user[ci]", required: true, autofocus: true, oninput: "$(this).val($(this).val().replace(/[^0-9]/g, ''))"}

  / Password
  = password_field_with_toggle name: :password, label: 'Contraseña *', size: 'lg', wrapper_class: 'mb-4', input_id: 'inputPassword5', input_attrs: { placeholder: 'Contraseña', autocomplete: 'current-password' }
  / Check box
  .mb-4.d-flex.justify-content-between.mb-4
    - if devise_mapping.rememberable?
      .form-check
        %input#exampleCheck1.form-check-input.boolean.optional{type: :checkbox, name: 'user[remember_me]'}
        %label.form-check-label{for: "exampleCheck1"} Recuérdame
    .text-primary-hover
      = link_to "Recuperar contraseña", new_user_password_path
  / Button
  .align-items-center.mt-0
    .d-grid
      %button.btn.btn-primary.mb-0{type: :submit} Entrar

