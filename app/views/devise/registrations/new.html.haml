%h2 Sign up
= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: :false }) do |f|
  = f.error_notification
  .form-inputs
    = f.input :email, required: true, autofocus: true, input_html: { autocomplete: "email" }
    = password_field_with_toggle name: :password, form_name: resource_name, label: 'Contraseña', input_attrs: { autocomplete: 'new-password' }
    = password_field_with_toggle name: :password_confirmation, form_name: resource_name, label: 'Confirmar contraseña', input_attrs: { autocomplete: 'new-password' }
  .form-actions
    = f.button :submit, "Sign up"
= render "devise/shared/links"
