<% params = request.params.except(:action, :controller, :model_name) %>
<% student_ci = params[:student_ci] %>
<% path_method = params[:id] ? "history_show_path" : "history_index_path" %>
<% is_section_bitacora = defined?(@bitacora_tab) && @bitacora_tab.present? %>

<% if is_section_bitacora %>
  <% section = @object %>
  <% teacher_name = (section.teacher&.user&.ci_fullname rescue nil) %>
  <% total_ar = section.total_academic_records rescue 0 %>
  <% pending = (section.total_sc rescue 0) %>
  <% graded = total_ar - pending %>
  <% subject_name = (section.subject&.name rescue nil) %>

  <div class="card mb-3">
    <div class="card-body py-2 px-3">
      <div class="d-flex flex-wrap align-items-center gap-3">
        <div>
          <span class="text-muted small">Sección</span>
          <strong class="font-monospace ms-1"><%= section.code %></strong>
        </div>
        <% if subject_name.present? %>
          <div>
            <span class="text-muted small">Asignatura</span>
            <strong class="ms-1"><%= subject_name %></strong>
          </div>
        <% end %>
        <div>
          <span class="text-muted small">Profesor</span>
          <% if teacher_name.present? %>
            <strong class="ms-1"><%= teacher_name %></strong>
          <% else %>
            <span class="badge bg-warning text-dark ms-1">No asignado</span>
          <% end %>
        </div>
        <div class="ms-auto d-flex gap-2">
          <span class="badge bg-success" title="Calificadas">
            <i class="fas fa-check"></i> Calificadas: <%= graded %>
          </span>
          <span class="badge bg-secondary" title="Faltan por calificar">
            <i class="fas fa-hourglass-half"></i> Faltan: <%= pending %>
          </span>
          <span class="badge bg-info text-dark" title="Total inscritos">
            <i class="fas fa-users"></i> Inscritos: <%= total_ar %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <% tab_labels = {
       'general'  => { label: 'General',     icon: 'fa-layer-group' },
       'students' => { label: 'Estudiantes', icon: 'fa-graduation-cap' }
     } %>

  <ul class="nav nav-tabs mb-3" role="tablist">
    <% tab_labels.each do |key, meta| %>
      <% count = (@bitacora_tab_counts || {})[key] || 0 %>
      <% active = (@bitacora_tab == key) %>
      <% tab_url = send(path_method, params.merge(id: params[:id], tab: key).except(:page, :all)) %>
      <li class="nav-item" role="presentation">
        <%= link_to tab_url, class: "nav-link #{'active' if active}", role: 'tab' do %>
          <i class="fas <%= meta[:icon] %>"></i>
          <%= meta[:label] %>
          <span class="badge bg-<%= active ? 'primary' : 'secondary' %> ms-1"><%= count %></span>
        <% end %>
      </li>
    <% end %>
  </ul>

  <% if student_ci.present? %>
    <div class="mb-3">
      <span class="badge bg-primary fs-6 p-2">
        <i class="fas fa-filter"></i>
        Filtro estudiante:
        <span class="font-monospace"><%= student_ci %></span>
        <% if @bitacora_focused_student %>
          — <%= @bitacora_focused_student.reverse_name rescue "#{@bitacora_focused_student.last_name}, #{@bitacora_focused_student.first_name}" %>
        <% end %>
        <%= link_to send(path_method, params.except(:student_ci).merge(id: params[:id])), class: "text-white ms-2" do %>
          <i class="fas fa-times-circle"></i> Quitar filtro
        <% end %>
      </span>
    </div>
  <% end %>

  <% if @bitacora_tab == 'students' && @bitacora&.qualifications_without_audit? %>
    <% audit_start = @bitacora.qualification_audit_start %>
    <div class="alert alert-warning d-flex align-items-start gap-2 py-2" role="alert">
      <i class="fas fa-triangle-exclamation mt-1"></i>
      <div class="small">
        <strong>Sin historial de notas para esta sección.</strong>
        Las calificaciones se registraron antes del
        <% if audit_start %>
          <strong><%= l(audit_start.in_time_zone('Caracas').to_date, format: :long) %></strong>,
        <% end %>
        cuando se activó el rastro de auditoría sobre calificaciones.
        Sólo se muestran los retiros y PI registrados sobre las inscripciones.
      </div>
    </div>
  <% end %>

  <style>
    #bitacora-table { width: 100%; table-layout: auto; }
    #bitacora-table th, #bitacora-table td {
      vertical-align: top;
      overflow: hidden;
      text-overflow: clip;
    }
    #bitacora-table th.col-fecha, #bitacora-table td.col-fecha { white-space: nowrap; min-width: 10.5rem; }
    #bitacora-table th.col-usuario, #bitacora-table td.col-usuario { white-space: nowrap; min-width: 14rem; }
    #bitacora-table th.col-estudiante, #bitacora-table td.col-estudiante { min-width: 16rem; }
    #bitacora-table th.col-dispositivo, #bitacora-table td.col-dispositivo { white-space: nowrap; min-width: 12rem; }
    #bitacora-table td.summary-cell { white-space: normal; min-width: 18rem; }
    #bitacora-table td.summary-cell code { display: block; white-space: normal; }
  </style>

  <% show_student_column = @bitacora_tab != 'general' %>
  <table class="table table-sm table-striped table-hover" id="bitacora-table">
    <thead>
      <tr>
        <th class="col-fecha">Fecha</th>
        <% if show_student_column %><th class="col-estudiante">Estudiante</th><% end %>
        <th>Resumen</th>
        <th class="col-usuario">Usuario</th>
        <th class="col-dispositivo">Dispositivo</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      <% if @history.empty? %>
        <tr>
          <td colspan="<%= show_student_column ? 5 : 4 %>" class="text-center text-muted py-4">
            Sin eventos en esta pestaña
          </td>
        </tr>
      <% else %>
        <% @history.each do |object| %>
          <tr>
            <td class="col-fecha">
              <% if object.created_at %>
                <span class="small font-monospace"
                      title="<%= l(object.created_at, format: :long) %>"
                      data-bs-toggle="tooltip">
                  <%= object.short_date %>
                </span>
              <% end %>
            </td>

            <% if show_student_column %>
              <td class="col-estudiante">
                <% if object.student_ci %>
                  <% filter_url = send(path_method, params.merge(id: params[:id], student_ci: object.student_ci).except(:page)) %>
                  <%= link_to filter_url, class: "text-decoration-none", title: "Filtrar por este estudiante" do %>
                    <div class="font-monospace small text-primary"><%= object.student_ci %></div>
                    <div class="text-muted small"><%= object.student_name %></div>
                  <% end %>
                <% else %>
                  <span class="text-muted small">—</span>
                <% end %>
              </td>
            <% end %>

            <td class="summary-cell">
              <strong><%= object.summary_title %></strong>
              <% if object.summary_detail.present? %>
                <div class="text-muted small mt-1"
                     title="<%= object.summary_detail %>"
                     data-bs-toggle="tooltip">
                  <code class="small text-body"><%= truncate(object.summary_detail, length: 140) %></code>
                </div>
              <% end %>
            </td>

            <td class="small col-usuario"><%= object.username %></td>

            <td class="small col-dispositivo">
              <% device = object.try(:device_label) %>
              <% ip = object.try(:ip) %>
              <% if device.present? || ip.present? %>
                <div title="<%= object.try(:user_agent) %>" data-bs-toggle="tooltip">
                  <% if device.present? %>
                    <div class="text-body"><%= device %></div>
                  <% end %>
                  <% if ip.present? %>
                    <div class="text-muted font-monospace small"><%= ip %></div>
                  <% end %>
                </div>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <script>
    (function() {
      if (window.bootstrap && bootstrap.Tooltip) {
        document.querySelectorAll('#bitacora-table [data-bs-toggle="tooltip"]').forEach(function(el) {
          new bootstrap.Tooltip(el);
        });
      }
    })();
  </script>
<% else %>
  <%= form_tag("", method: "get", class: "search form-inline") do %>
    <div class="input-group mb-3">
      <input class="form-control" name="query" placeholder="<%= t('admin.misc.filter') %>" type="search" value="<%= params[:query] %>" />
      <button class="btn btn-primary" type="submit"><i class="fas fa-sync"></i> <%= t("admin.misc.refresh") %></button>
    </div>
  <% end %>
  <table class="table table-condensed table-striped table-hover" id="history">
    <thead>
      <tr>
        <th class="header">Fecha de Acción</th>
        <th class="header">Acción</th>
        <th class="header">Usuario</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      <% @history.each do |object| %>
        <tr>
          <td>
            <% if object.created_at %>
              <span title="<%= l(object.created_at, format: :long) %>">
                <%= l(object.created_at.in_time_zone('Caracas'), format: :long) rescue l(object.created_at, format: :long) %>
              </span>
            <% end %>
          </td>
          <td><%= object.message.in?(['delete', 'new']) ? t("admin.actions.#{object.message}.done").capitalize : object.message %></td>
          <td><%= object.username %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% unless params[:all] || !@history.respond_to?(:current_page) %>
  <%= paginate(@history, theme: 'ra-twitter-bootstrap') %>
  <%= link_to(t("admin.misc.show_all"), send(path_method, params.merge(all: true)), class: "show-all btn btn-light") unless (tc = @history.total_count) <= @history.size || tc > 500 %>
<% end %>
